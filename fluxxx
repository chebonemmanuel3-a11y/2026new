const { Module } = require("../main");
const axios = require("axios");

// --- Configuration ---
// In 2026, Flux Schnell is the best balance of quality and speed for bots.
const FLUX_API_URL = "https://api.flux-ai.io/v1/generate"; // Example 2026 production endpoint
const API_KEY = "YOUR_FLUX_API_KEY"; // Replace with your actual key

/**
 * Generates an image using Flux AI
 */
async function generateFluxImage(prompt) {
    try {
        const response = await axios.post(FLUX_API_URL, {
            prompt: prompt,
            model: "flux-2-schnell", // High speed, high accuracy
            width: 1024,
            height: 1024,
            steps: 4, // Schnell only needs 1-4 steps for a clear image
            response_format: "url"
        }, {
            headers: {
                'Authorization': `Bearer ${API_KEY}`,
                'Content-Type': 'application/json'
            },
            timeout: 30000
        });

        return response.data?.url;
    } catch (error) {
        console.error("Flux API Error:", error.message);
        return null;
    }
}

// --- Command Module (.flux) ---

Module(
    {
        pattern: "flux ?(.*)",
        desc: "Generate high-quality images using Flux AI.",
        use: "ai",
        usage: ".flux a futuristic Nairobi street with flying matatus"
    },
    async (message, match) => {
        const prompt = match[1]?.trim();

        if (!prompt) {
            return await message.sendReply("🎨 *Flux Image AI*\n\nProvide a prompt to generate an image.\n*Example:* `.flux a neon-lit cyber-lion in the savannah`.");
        }

        // 1. Send initial loading feedback
        const loading = await message.sendReply(`🎨 _Flux is painting your vision..._ \n\n*"${prompt}"*`);

        try {
            // 2. Call Flux API
            const imageUrl = await generateFluxImage(prompt);

            if (imageUrl) {
                // 3. Send the image and edit/delete the loading message
                await message.sendMessage({ url: imageUrl }, "image", {
                    caption: `*🔥 Generated by Flux AI*\n\n_Prompt: ${prompt}_`,
                    quoted: message
                });
                
                // Using the edit logic you like to clean up the chat
                await message.edit("✅ _Image Generated!_", message.jid, loading.key);
            } else {
                await message.edit("❌ _Failed to generate image. Please try again later._", message.jid, loading.key);
            }

        } catch (e) {
            await message.edit(`_❌ Critical Error: ${e.message}_`, message.jid, loading.key);
        }
    }
);
