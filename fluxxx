const { Module } = require("../main");
const axios = require("axios");

// --- Configuration ---
// Puter.js allows access to Flux models without personal API keys.
const PUTER_API_URL = "https://api.puter.com/v1/ai/txt2img"; 

/**
 * Generates an image using Flux via Puter.js
 */
async function generateFluxImage(prompt) {
    try {
        // Flux.1 Schnell is optimized for speed (~1-2 seconds).
        const response = await axios.post(PUTER_API_URL, {
            prompt: prompt,
            model: "black-forest-labs/flux.1-schnell", 
            width: 1024,
            height: 1024
        }, {
            // Puter's keyless integration often uses session-based or public tokens
            headers: { 'Content-Type': 'application/json' },
            timeout: 40000
        });

        // Puter returns the image element or URL directly.
        return response.data?.url || response.data?.image_url;
    } catch (error) {
        console.error("Flux Error:", error.message);
        return null;
    }
}

Module(
    {
        pattern: "flux ?(.*)",
        desc: "Generate high-quality images using Flux (No Key Required).",
        use: "ai"
    },
    async (message, match) => {
        const prompt = match[1]?.trim();
        if (!prompt) return await message.sendReply("🎨 Provide a prompt! Example: `.flux a cyber-matatu in Nairobi`.");

        const loading = await message.sendReply(`🎨 _Flux is painting your vision..._`);

        try {
            const imageUrl = await generateFluxImage(prompt);
            if (imageUrl) {
                await message.sendMessage({ url: imageUrl }, "image", {
                    caption: `*🔥 Flux AI Output*\n\n_Prompt: ${prompt}_`,
                    quoted: message
                });
                await message.edit("✅ _Done!_", message.jid, loading.key);
            } else {
                await message.edit("❌ _Generation failed. Try again._", message.jid, loading.key);
            }
        } catch (e) {
            await message.edit(`_❌ Error: ${e.message}_`, message.jid, loading.key);
        }
    }
);
