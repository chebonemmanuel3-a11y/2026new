const { Module } = require("../main");
const config = require("../config");
const axios = require("axios");

// --- API Configuration ---
const API_BASE_URL = "https://generativelanguage.googleapis.com/v1beta/models/";
const MODEL = "gemini-2.5-flash-lite"; 

/**
 * Calls Gemini to translate text.
 */
async function translateText(text, targetLang) {
    const apiKey = config.GEMINI_API_KEY;
    if (!apiKey) return "_❌ API Key not found._";

    const apiUrl = `${API_BASE_URL}${MODEL}:generateContent?key=${apiKey}`;

    const systemPrompt = `You are an expert translator specializing in East African context. Translate text to ${targetLang}. If target is Sheng, use modern Kenyan slang. Return ONLY the translated text.`;

    const payload = {
        contents: [{ parts: [{ text: `Translate this: "${text}" to ${targetLang}` }] }],
        systemInstruction: { parts: [{ text: systemPrompt }] },
    };

    try {
        const response = await axios.post(apiUrl, payload);
        return response.data?.candidates?.[0]?.content?.parts?.[0]?.text || "_❌ Translation failed._";
    } catch (error) {
        return `_❌ Error: ${error.message}_`;
    }
}

// --- Command Module Definition (.tr) ---

Module(
    {
        pattern: "tr ?(.*)",
        fromMe: false,
        desc: "Translate text with a clean message edit.",
        usage: ".tr sheng [text]",
        type: "ai"
    },
    async (message, match) => {
        const input = match[1]?.trim();
        const spaceIndex = input.indexOf(' ');

        if (spaceIndex === -1) {
            return await message.sendReply("🌍 *Usage:* `.tr [lang] [text]`\n*Example:* `.tr sheng come here`.");
        }

        const targetLang = input.substring(0, spaceIndex);
        const textToTranslate = input.substring(spaceIndex + 1);

        // 1. Send the initial loading message and store it
        const loadingMsg = await message.sendReply(`🌍 _Translating to ${targetLang}..._`);

        try {
            // 2. Get the translation
            const result = await translateText(textToTranslate, targetLang);

            // 3. Edit the original loading message with the final result
            // This follows the edit logic from your 'gen' script
            const finalReply = `*🌍 Translation (${targetLang}):*\n\n${result}`;
            
            await message.edit(finalReply, message.jid, loadingMsg.key);

        } catch (e) {
            await message.edit(`_❌ Error: ${e.message}_`, message.jid, loadingMsg.key);
        }
    }
);
